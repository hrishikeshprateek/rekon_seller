{
  "projects": {
    "default": {
      "hosting": {
        "public": "build/web",
        "ignore": [
          "firebase.json",
          "**/.*",
          "**/node_modules/**"
        ],
        "rewrites": [
          {
            "source": "**",
            "destination": "/index.html"
          }
        ],
        "headers": [
          {
            "source": "**/*.@(js|css|json)",
            "headers": [
              {
                "key": "Cache-Control",
                "value": "public, max-age=31536000, immutable"
              }
            ]
          },
          {
            "source": "/index.html",
            "headers": [
              {
                "key": "Cache-Control",
                "value": "public, max-age=3600"
              }
            ]
          },
          {
            "source": "**/*.@(png|jpg|jpeg|gif|svg|webp|ico)",
            "headers": [
              {
                "key": "Cache-Control",
                "value": "public, max-age=31536000"
              }
            ]
          }
        ],
        "cleanUrls": true
      }
    }
  }
}

